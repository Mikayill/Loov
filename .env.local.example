# ─────────────────────────────────────────────────────────────
# Loov — environment variables (Phase 2 backend)
# Copy this file to ".env.local" and fill in real values.
# NEVER commit .env.local (it is gitignored by default).
# ─────────────────────────────────────────────────────────────

# Supabase — create a free project at https://supabase.com
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only secret — DO NOT expose to the browser (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (order confirmation + tracking) — https://resend.com
RESEND_API_KEY=

# SMS (order confirmation + tracking) — e.g. https://twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+995...

# Site URL used in emails/links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
